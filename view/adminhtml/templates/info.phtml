<?php
$moduleTitleJs   = $escaper->escapeJs($moduleTitle);
$remindLaterUrl  = $escaper->escapeJs($block->escapeUrl($block->getUrl('mfcommunity/remindlater/index')));
$script = <<<JS
function mfRemindLater(el, event) {
    var messageBlock = el.closest('.message');
    if (messageBlock) {
        messageBlock.style.transition = 'opacity 0.5s';
        messageBlock.style.opacity = '0';
        setTimeout(function() { messageBlock.style.display = 'none'; }, 500);
        require(['jquery', 'domReady!'], function($) {
            $.ajax({
                url: '{$remindLaterUrl}',
                type: 'post',
                dataType: 'json',
                data: {
                    event: event,
                    module: '{$moduleTitleJs}'
                },
                success: function(data) {
                    console.log(data);
                }
            });
        });
    }
}
JS;
echo $mfSecureRenderer->renderTag('script', [], $script, false);
?>
